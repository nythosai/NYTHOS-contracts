# Copy this to .env and fill in your values

# Your deployer wallet private key (the wallet that will pay gas)
# Get from MetaMask: Account Details → Export Private Key
# NEVER share this or commit it to GitHub
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Basescan API key for contract verification (free at basescan.org/login)
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY_HERE
